---
interface Props {
	class?: string;
}

const { class: className = "relative w-full aspect-square flex items-center justify-center" } = Astro.props;
---
<div class={className}>
	<!-- Unified SVG Architecture -->
	<svg class="absolute inset-0 w-full h-full overflow-visible" viewBox="0 0 200 200">
		<defs>
			<!-- High-Tech Glow Filter -->
			<filter id="block-glow" x="-50%" y="-50%" width="200%" height="200%">
				<feGaussianBlur stdDeviation="3" result="blur" />
				<feComposite in="SourceGraphic" in2="blur" operator="over" />
			</filter>
		</defs>

		<!-- Background Grid (subtle) -->
		<g class="stroke-primary-500/10" stroke-width="0.5">
			<line x1="0" y1="40" x2="200" y2="40" />
			<line x1="0" y1="100" x2="200" y2="100" />
			<line x1="0" y1="160" x2="200" y2="160" />
			<line x1="40" y1="0" x2="40" y2="200" />
			<line x1="100" y1="0" x2="100" y2="200" />
			<line x1="160" y1="0" x2="160" y2="200" />
		</g>

		<!-- Connections Base -->
		<g fill="none" stroke="currentColor" class="text-primary-500/20 dark:text-primary-400/20" stroke-width="2">
			<path d="M 40 100 L 80 100 L 80 60 L 120 60" />
			<path d="M 40 100 L 80 100 L 80 140 L 120 140" />
			<path d="M 120 60 L 160 60 L 160 100" />
			<path d="M 120 140 L 160 140 L 160 100" />
			<path d="M 160 100 L 180 100" />
		</g>

		<!-- Animated Flow Lines -->
		<g fill="none" stroke="currentColor" class="text-primary-400 dark:text-primary-300" stroke-width="2" stroke-linecap="round">
			<path d="M 40 100 L 80 100 L 80 60 L 120 60" class="flow-pulse-js opacity-0" />
			<path d="M 40 100 L 80 100 L 80 140 L 120 140" class="flow-pulse-js opacity-0" />
			<path d="M 120 60 L 160 60 L 160 100" class="flow-pulse-js opacity-0" />
			<path d="M 120 140 L 160 140 L 160 100" class="flow-pulse-js opacity-0" />
			<path d="M 160 100 L 180 100" class="flow-pulse-js opacity-0" />
		</g>

		<!-- Blocks -->
		<g class="fill-neutral-50 dark:fill-neutral-900 stroke-primary-500 stroke-[1.5px]" filter="url(#block-glow)">
			<!-- Input Block -->
			<rect x="20" y="85" width="20" height="30" rx="2" />
			<!-- Process Block 1 -->
			<rect x="100" y="45" width="30" height="30" rx="2" />
			<!-- Process Block 2 -->
			<rect x="100" y="125" width="30" height="30" rx="2" />
			<!-- Output Block -->
			<rect x="150" y="85" width="20" height="30" rx="2" />
		</g>
		
		<!-- Block Inner Details -->
		<g class="fill-primary-500/50">
			<circle cx="30" cy="100" r="3" />
			<rect x="105" y="55" width="20" height="4" rx="1" />
			<rect x="105" y="65" width="12" height="4" rx="1" />
			<rect x="105" y="135" width="20" height="4" rx="1" />
			<rect x="105" y="145" width="16" height="4" rx="1" />
			<circle cx="160" cy="100" r="4" class="fill-primary-400 animate-ping opacity-40" style="animation-duration: 2s;" />
			<circle cx="160" cy="100" r="4" class="fill-primary-500" />
		</g>

		<!-- Labels -->
		<g class="fill-neutral-500 dark:fill-neutral-400 font-mono text-[6px]">
			<text x="30" y="125" text-anchor="middle">DATA_IN</text>
			<text x="115" y="40" text-anchor="middle">STRATEGY</text>
			<text x="115" y="165" text-anchor="middle">EXECUTE</text>
			<text x="160" y="125" text-anchor="middle">SYNC_OUT</text>
		</g>
	</svg>

	<!-- Flow Pulse JS Controller -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const pulses = document.querySelectorAll('.flow-pulse-js');
			pulses.forEach((pulse, index) => {
				if (!(pulse instanceof SVGPathElement)) return;
				
				const length = pulse.getTotalLength();
				const dashLength = 20;
				// Set stroke array: dash length followed by massive gap
				(pulse as SVGElement).style.strokeDasharray = `${dashLength} ${length * 2 + dashLength * 2}`;
				
				let isShooting = false;
				
				function shoot() {
					if (isShooting) return;
					isShooting = true;
					
					// Ensure pulse is visible before animating
					(pulse as SVGElement).style.opacity = '1';
					
					// Random speed between 1.0s and 2.5s
					const duration = 1000 + Math.random() * 1500;
					
					// Animate dash offset to travel full length
					const animation = pulse.animate([
						{ strokeDashoffset: dashLength },
						{ strokeDashoffset: -length }
					], {
						duration: duration,
						easing: 'ease-in-out'
					});
					
					animation.onfinish = () => {
						isShooting = false;
						(pulse as SVGElement).style.opacity = '0';
						// Random rest period between 0.2s and 1s before next shot
						setTimeout(shoot, 200 + Math.random() * 1000);
					};
				}
				
				// Start shoot with staggered delay
				setTimeout(shoot, index * 600 + Math.random() * 1000);
			});
		});
	</script>
</div>