---
// Section with Image
// ------------
// Description: a foundational component representing a section of content within page. The section component can contain any number of rows. This is a variant of the Section component that allows you to easily add a side image to the section.
// Properties:
// - Id: the id of the section
// - Mode:  use that to overide the light/dark mode for a specific section. Usefull if you have a section that might contain a dark background
// - Padding: by default each section has a vertical padding. The padding property defines where the padding is applied (top, bottom, both, none), default is both
// - Image: The image to be placed at the side of the section. The image will be placed on the right side of the section on desktop and will be hidden on mobile
// - classes: additional classes
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

// Props
type Props = {
	id?: string
	mode?: 'dark' | 'light'
	padding?: 'both' | 'top' | 'bottom' | 'none'
	image: ImageMetadata
	imageAlt?: string
	classes?: string
	imageClasses?: string
	surfaceColor?: boolean
	fullHeight?: boolean
	reverse?: boolean
}
const {
	id,
	mode,
	padding = 'both',
	classes,
	image,
	imageAlt,
	imageClasses,
	surfaceColor,
	fullHeight,
	reverse
} = Astro.props
---

<section
	{...id ? { id } : {}}
	class:list={[
		'section',
		surfaceColor ? 'section--surface' : 'section-neutral',
		fullHeight ? 'md:h-dvh md:max-h-[1080px]' : '',
		reverse ? 'flex-row-reverse' : '',
		{ 'section--padded': padding === 'both' },
		{ 'section--padded-t': padding === 'top' },
		{ 'section--padded-b': padding === 'bottom' },
		{ [`${mode}`]: mode },
		{ [`${classes}`]: classes }
	]}
>
	<div class="container flex flex-col items-center justify-around gap-y-12 md:flex-row">
		<div class="flex w-full items-center px-6 py-12 md:w-[45%] lg:px-8 lg:py-24">
			<slot />
		</div>
		<div class="relative hidden h-[600px] w-full md:block md:w-[45%]">
			<Image
				class:list={['h-full w-full max-w-lg object-cover', { [`${imageClasses}`]: imageClasses }]}
				src={image}
				loading="eager"
				alt={imageAlt || 'Section image'}
			/>
		</div>
	</div>
</section>

<style>
	.section {
		@apply relative flex w-full text-neutral-500 dark:text-neutral-400 [&.dark]:text-neutral-400 [&.light]:text-neutral-500 [&.section--sticky-col_.container]:h-full [&:not(.section--sticky-col)]:overflow-hidden;
	}

	.section--neutral {
		@apply [&.dark:not([class*='bg-'])]:bg-neutral-950 [&.light:not([class*='bg-'])]:bg-neutral-50 [&.light]:bg-neutral-50;
	}

	.section--surface {
		@apply [&.dark:not([class*='bg-'])]:bg-surface-950 [&.light:not([class*='bg-'])]:bg-surface-50 [&.light]:bg-surface-50;
	}

	.section--padded {
		@apply py-12 lg:py-24;
	}
	.section--padded-t {
		@apply pt-12 lg:pt-24;
	}
	.section--padded-b {
		@apply pb-12 lg:pb-24;
	}
	.section__bg {
		@apply absolute inset-0 bg-cover;
	}
	.container {
		@apply relative z-[1] mx-auto px-6 [.section--fullwidth_&]:max-w-full [.section--fullwidth_&]:px-0;
	}
</style>
