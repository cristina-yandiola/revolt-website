---
// Card
// ------------
// Description: the basic card foundation. Contains the background, shadow and border radius
// Properties:
// - link: will allow the whole card to be linkable
// - classes: extra classes

// Props
type Props = {
	link?: string
	classes?: string
	tags?: string[]
}
const { link, classes, tags = [] } = Astro.props
---

{
	link ? (
		<a
			href={link}
			class:list={['card', { [`${classes}`]: classes }]}
			data-tags={tags.length > 0 ? tags.join(',') : undefined}
		>
			<slot />
		</a>
	) : (
		<div
			class:list={['card', { [`${classes}`]: classes }]}
			data-tags={tags.length > 0 ? tags.join(',') : undefined}
		>
			<slot />
		</div>
	)
}
<style>
	.card {
		@apply flex flex-col overflow-hidden rounded border border-neutral-100 bg-white text-neutral-500 shadow-lg shadow-neutral-700/5 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-neutral-950/50;
	}
</style>
