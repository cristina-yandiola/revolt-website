---
// About Feature List Section
// ------------
// Description: A list of features with icons and descriptions in a 4 column layout for the about page.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Feature from '../../ui/Feature.astro'

// Props
type Props = {
	id?: string
	title?: string
	text?: string
	classes?: string
	features?: Array<{
		title: string
		description: string
		icon?: string
	}>
}
const {
	id = 'about-features',
	title = 'Our Methodology',
	text = 'How we improve what is within your control to accelerate your grid access timeline.',
	classes = '',
	features = [
		{
			title: 'Data-Driven Site Selection',
			description: 'Selecting sites with higher chances of grid approval through data-driven screening',
			icon: 'chart-pie'
		},
		{
			title: 'Strategic Pipeline Structuring',
			description: 'Structuring your pipeline across operators, regions, and voltage levels to balance speed, risk, and connection outcomes',
			icon: 'rectangle-stack'
		},
		{
			title: 'Senior Expert Support',
			description: 'Providing senior-level support on applications, grid operator interface, and critical processes such as BNetzA procedures',
			icon: 'user'
		},
		{
			title: 'Automated Workflows',
			description: 'Automating grid application workflows to cut workload and accelerate speed to grid',
			icon: 'computer-desktop'
		},
		{
			title: 'Team Training & Enablement',
			description: 'Training your team to reach operational competence and faster execution from week one',
			icon: 'book'
		}
	]
} = Astro.props
---

<Section id={id} classes={classes}>
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">{title}</h2>
			<p class="pb-0 text-lg">{text}</p>
		</Col>
	</Row>
	<Row>
		{
			(features || []).map((feature, _) => (
				<Col span="3">
					<Feature title={feature.title} icon={feature.icon} align="left" classes="mb-12">
						{feature.description}
					</Feature>
				</Col>
			))
		}
	</Row>
</Section>
