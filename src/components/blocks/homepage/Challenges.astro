---
// Challenges Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Eyebrow from '../../ui/Eyebrow.astro'
---

<Section id="challenges" classes="bg-surface-100" surfaceColor>
	<Row classes="items-start gap-y-10">
		<Col span="4">
			<Eyebrow title="The Critical Path" />
			<h2
				class="max-w-sm font-headings text-3xl font-bold leading-tight text-neutral-700 lg:text-4xl"
			>
				Speed to grid is more critical than ever
			</h2>
		</Col>
		<Col span="6" classes="lg:col-start-7">
			<div class="max-w-2xl">
				<p class="text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
					In Germany, project viability increasingly depends on connection strategy, congestion
					exposure, and network constraints.
				</p>
				<p class="text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
					Revolt helps teams identify stronger connection opportunities earlier and make more
					informed development and investment decisions.
				</p>

				<div class="mt-8 border-t border-primary-600 pt-8 dark:border-primary-500/40">
					<div class="grid gap-8 sm:grid-cols-2">
						<div>
							<p class="mb-1 font-headings text-4xl font-bold tracking-tight text-primary-800">
								340+
							</p>
							<p class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-neutral-700">
								Substations Analyzed
							</p>
						</div>
						<div>
							<p class="mb-1 font-headings text-4xl font-bold tracking-tight text-primary-800">
								12GW+
							</p>
							<p class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-neutral-700">
								Projects Analyzed
							</p>
						</div>
					</div>
				</div>
			</div>
		</Col>
	</Row>
</Section>
