---
// Challenges Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Button from '../../ui/Button.astro'
import { Image } from 'astro:assets'
import electricGridImg from '../../../assets/electric-grid.jpg'
---

<Section id="challenges" classes="py-12 lg:py-24 bg-white dark:bg-neutral-950">
	<Row classes="mb-12">
		<Col span="12">
			<h2 class="mb-4 font-headings text-4xl font-bold">Core Industry Challenges</h2>
			<p class="max-w-xl text-neutral-600 dark:text-neutral-400">
				Application outcomes are uncertain. We focus on the high-risk intersections of modern
				infrastructure.
			</p>
		</Col>
	</Row>
	<Row classes="gap-y-6 lg:gap-x-6">
		<!-- Card 1: BESS Operations -->
		<Col span="8" classes="h-full">
			<div
				class="group relative flex h-[400px] overflow-hidden rounded-sm border border-neutral-100 shadow-sm transition-all hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900"
			>
				<div class="z-10 flex w-full flex-col justify-between p-8 lg:w-1/2">
					<div>
						<span
							class="mb-4 inline-block font-mono text-sm font-bold uppercase tracking-wider text-neutral-400"
							>01</span
						>
						<h3 class="mb-4 font-headings text-3xl font-bold">BESS Operations</h3>
						<p class="text-neutral-600 dark:text-neutral-400">
							Optimizing battery energy storage systems against volatile grid constraints and
							frequency response demands.
						</p>
					</div>
					<Button
						variation="link"
						style="primary"
						link="/courses"
						classes="!p-0 font-bold uppercase tracking-widest group-hover:translate-x-2 transition-transform"
					>
						EXPLORE FORMATION &rarr;
					</Button>
				</div>
				<div
					class="absolute right-0 top-0 hidden h-full w-1/2 overflow-hidden bg-neutral-900 lg:block dark:bg-neutral-950"
				>
					<Image
						src={electricGridImg}
						alt="Electric Grid Infrastructure"
						class="h-full w-full object-cover opacity-60 dark:opacity-40"
					/>
				</div>
			</div>
		</Col>

		<!-- Card 2: Renewables -->
		<Col span="4" classes="h-full">
			<div
				class="flex h-[400px] flex-col justify-between rounded-sm bg-primary-600 p-8 text-white shadow-sm transition-all hover:shadow-md dark:bg-primary-800"
			>
				<div>
					<span
						class="mb-4 inline-block font-mono text-sm font-bold uppercase tracking-wider text-primary-200"
						>02</span
					>
					<h3 class="mb-4 font-headings text-3xl font-bold text-neutral-800">Renewables</h3>
					<p class="text-primary-50:">
						Solving the interconnection puzzle for utility-scale solar and wind projects.
					</p>
				</div>
				<div class="mt-8 h-1 w-full bg-accent-400"></div>
			</div>
		</Col>

		<!-- Card 3: Data Centres -->
		<Col span="4" classes="h-full">
			<div
				class="flex h-[400px] flex-col justify-between rounded-sm border border-transparent bg-neutral-100 p-8 shadow-sm transition-all hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900"
			>
				<div>
					<span
						class="mb-4 inline-block font-mono text-sm font-bold uppercase tracking-wider text-neutral-400"
						>03</span
					>
					<h3 class="mb-4 font-headings text-3xl font-bold">Data Centres</h3>
					<p class="font-sans leading-relaxed text-neutral-600 dark:text-neutral-400">
						Securing firm power in an increasingly saturated energy market.
					</p>
				</div>
				<div class="mt-auto flex gap-1">
					<div class="h-4 w-6 bg-neutral-300 dark:bg-neutral-700"></div>
					<div class="h-4 w-6 bg-neutral-300 dark:bg-neutral-700"></div>
				</div>
			</div>
		</Col>

		<!-- Card 4: Grid Efficiency -->
		<Col span="8" classes="h-full">
			<div
				class="flex h-[400px] flex-col items-center rounded-sm bg-accent-400 p-8 text-neutral-950 shadow-sm transition-all hover:shadow-md lg:flex-row dark:bg-accent-500"
			>
				<div class="mb-8 lg:mb-0 lg:w-1/2">
					<span class="text-7xl font-bold tracking-tighter lg:text-8xl">98%</span>
					<p class="text-sm font-bold uppercase tracking-widest text-neutral-800">
						GRID EFFICIENCY FOCUS
					</p>
				</div>
				<div class="lg:w-1/2">
					<p class="text-xl font-medium leading-relaxed">
						We break away from slow, inefficient processes by delivering deep operational expertise.
					</p>
				</div>
			</div>
		</Col>
	</Row>
</Section>
