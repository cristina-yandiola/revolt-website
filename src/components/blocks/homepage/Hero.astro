---
// Hero Section
// ------------
import SectionWithImage from '../../ui/SectionWithImage.astro'
import Button from '../../ui/Button.astro'
import heroImage from '../../../assets/home-hero.jpeg'
import { Icon } from 'astro-icon/components'
---

<SectionWithImage
	id="hero"
	image={heroImage}
	imageAlt="Technical aerial view of a large scale battery energy storage system facility with white containers and power transformers under clear daylight"
	surfaceColor
	mode="light"
	fullHeight
	imageClasses="grayscale-[0.2] contrast-[1.1]"
>
	<div class="relative z-10 flex flex-col justify-center">
		<p class="mb-4 text-xs font-bold uppercase tracking-widest text-primary-500">
			Grid Intelligence
		</p>
		<h1 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
			Decision-grade Grid Intelligence for Energy Infrastructure.
		</h1>
		<p class="mb-10 max-w-xl text-lg leading-relaxed text-neutral-600">
			Revolt helps developers and investors prioritize connection opportunities, assess grid-related
			investment risk, and make faster decisions across BESS, renewables, and data centres.
		</p>
		<div class="flex flex-wrap gap-4">
			<Button size="lg" link="/gridscore" style="accent-light"> View GridScore</Button>
			<Button variation="link" style="neutral" size="lg" link="/contact">
				<span
					class="flex items-center border-b-2 border-neutral-500 px-0.5 pb-1 font-bold uppercase transition-colors duration-200 hover:text-primary-700"
				>
					Book a Call
					<Icon name="arrow-right" class="ml-2" />
				</span>
			</Button>
		</div>
	</div>
</SectionWithImage>
