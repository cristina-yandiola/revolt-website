---
// Hero Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Button from '../../ui/Button.astro'
import Interactive3DCubes from '../../ui/Interactive3DCubes.astro'
---

<Section
	id="hero"
	classes="pt-24 pb-12 lg:pt-32 lg:pb-24 overflow-hidden bg-neutral-50 dark:bg-neutral-950"
>
	<!-- Blueprint Grid Background (Full screen width) -->
	<div
		class="pointer-events-none absolute left-1/2 top-0 z-[-1] h-full w-[100vw] -translate-x-1/2 [-webkit-mask-image:linear-gradient(to_bottom,transparent,black_15%,black_85%,transparent)] [mask-image:linear-gradient(to_bottom,transparent,black_15%,black_85%,transparent)]"
	>
		<div
			class="absolute inset-0 bg-[linear-gradient(to_right,currentColor_1px,transparent_1px),linear-gradient(to_bottom,currentColor_1px,transparent_1px)] bg-[size:64px_64px] text-neutral-900/5 dark:text-white/5"
		>
		</div>
	</div>

	<!-- Technical Accents -->
	<div
		class="pointer-events-none absolute -left-4 top-24 hidden rotate-180 font-mono text-[10px] tracking-[0.2em] text-neutral-400/60 [writing-mode:vertical-lr] lg:-left-12 lg:block"
	>
		// SYS.GRID_INIT_01
	</div>
	<div
		class="pointer-events-none absolute -right-4 top-24 hidden rotate-180 font-mono text-[10px] tracking-[0.2em] text-neutral-400/60 [writing-mode:vertical-lr] lg:-right-12 lg:block"
	>
		LAT_45.02 // LON_-93.22
	</div>

	<Row>
		<Col span="6" classes="relative flex flex-col justify-center z-10">
			<Interactive3DCubes interactive={false} class="absolute inset-0 -z-10 opacity-10 lg:hidden" />
			<p
				class="mb-4 text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400"
			>
				Grid Access Strategy
			</p>
			<h1 class="mb-8 font-headings text-5xl font-bold leading-tight lg:text-7xl">
				Navigating <span class="italic text-primary-600 dark:text-primary-400">Grid Access</span> Risks.
			</h1>
			<p class="mb-10 max-w-xl text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				Across BESS, renewables, and data centres, timelines are slipping. Grid access has become
				one of the largest investment risks. Revolt was built to improve what is within your
				control.
			</p>
			<div class="flex flex-wrap gap-4">
				<Button size="lg" link="/courses">VIEW COURSES</Button>
				<Button variation="outline" size="lg" link="/contact">GET IN TOUCH</Button>
			</div>
		</Col>
		<Col span="6" classes="relative mt-12 hidden lg:block lg:mt-0">
			<div class="group relative aspect-square w-full overflow-hidden rounded-sm">
				<!-- Dynamic 3D Cubes -->
				<Interactive3DCubes />
			</div>
		</Col>
	</Row>
</Section>
