---
// Hero Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Button from '../../ui/Button.astro'
---

<Section
	id="hero"
	classes="pt-24 pb-12 lg:pt-32 lg:pb-24 overflow-hidden bg-white dark:bg-neutral-950"
>
	<Row>
		<Col span="6" classes="flex flex-col justify-center">
			<p
				class="mb-4 text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400"
			>
				Grid Access Strategy
			</p>
			<h1 class="mb-8 font-headings text-5xl font-bold leading-tight lg:text-7xl">
				Navigating <span class="italic text-primary-600 dark:text-primary-400">Grid Access</span> Risks.
			</h1>
			<p class="mb-10 max-w-xl text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				Across BESS, renewables, and data centres, timelines are slipping. Grid access has become
				one of the largest investment risks. Revolt was built to improve what is within your
				control.
			</p>
			<div class="flex flex-wrap gap-4">
				<Button size="lg" link="/courses">VIEW COURSES</Button>
				<Button variation="outline" size="lg" link="/contact">GET IN TOUCH</Button>
			</div>
		</Col>
		<Col span="6" classes="relative mt-12 lg:mt-0">
			<div
				class="group relative aspect-square w-full overflow-hidden rounded-sm bg-neutral-100 dark:bg-neutral-900"
			>
				<div
					class="absolute inset-0 animate-pulse bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary-500 via-transparent to-transparent opacity-20"
				>
				</div>
				<!-- Placeholder for the grid visual -->
				<div class="absolute inset-0 flex items-center justify-center">
					<div
						class="h-3/4 w-3/4 animate-[spin_20s_linear_infinite] rounded-full border border-dashed border-primary-200 dark:border-primary-800"
					>
					</div>
					<div
						class="absolute h-1/2 w-1/2 animate-[spin_15s_linear_infinite_reverse] rounded-full border border-primary-300 dark:border-primary-700"
					>
					</div>
				</div>
			</div>
		</Col>
	</Row>
</Section>
