---
// Solution Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import electricGridImg from '../../../assets/powerlines.png'

const bulletPoints: { icon: string; text: string }[] = [
	{
		icon: 'chart-pie',
		text: 'Connection point ranking and prioritization'
	},
	{
		icon: 'file-chart-column-increasing',
		text: 'Congestion and redispatch exposure analysis'
	},
	{
		icon: 'gauge',
		text: 'Capacity and regulatory signal mapping'
    },
	{
		icon: 'bolt',
		text: 'Strategic support for BESS and flexible assets'
	}
]
---

<Section id="solution" classes="bg-white py-12 lg:py-24 dark:bg-neutral-950">
	<div
		class="absolute -bottom-12 -top-12 left-[calc(50%-50vw)] right-1/2 hidden lg:-bottom-24 lg:-top-24 lg:block"
	>
		<Image
			src={electricGridImg}
			alt="Transmission grid infrastructure"
			class="h-full w-full object-cover grayscale"
		/>
		<div class="absolute inset-0 bg-neutral-950/15 dark:bg-neutral-950/35"></div>
	</div>
	<Row classes="items-stretch gap-y-10">
		<Col span="6" classes="lg:hidden">
			<div class="relative min-h-[360px] overflow-hidden">
				<Image
					src={electricGridImg}
					alt="Transmission grid infrastructure"
					class="absolute inset-0 h-full w-full object-cover grayscale"
				/>
				<div class="absolute inset-0 bg-neutral-950/15 dark:bg-neutral-950/35"></div>
			</div>
		</Col>
		<Col span="6" classes="hidden lg:block" />
		<Col span="6" classes="relative z-10 flex flex-col justify-center lg:pl-12">
			<h2
				class="mb-6 max-w-xl font-headings text-3xl font-bold leading-tight text-primary-700 lg:text-4xl"
			>
				Advanced Capacity Intelligence
			</h2>
			<p class="mb-10 max-w-xl leading-relaxed text-neutral-600 dark:text-neutral-400">
				Our proprietary analytics framework evaluates congestion exposure, connection constraints,
				and capacity signals across Germany’s transmission network to support faster and more
				informed siting decisions for BESS and flexible assets.
			</p>
			<ul class="space-y-8">
				{
					bulletPoints.map((point) => (
						<li class="flex items-center gap-3">
							<Icon name={point.icon} class="h-6 w-6 shrink-0 text-primary-700" />
							<div>
								<h3 class="text-lg text-neutral-600">{point.text}</h3>
							</div>
						</li>
					))
				}
			</ul>
		</Col>
	</Row>
</Section>
