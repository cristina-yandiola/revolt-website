---
// Solution Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import cubeNetworkImg from '../../../assets/cube-grid-electric.webp'
---

<Section id="solution" classes="py-12 lg:py-24 bg-neutral-50 dark:bg-neutral-900/50">
	<Row classes="items-center">
		<Col span="6">
			<h2 class="mb-6 font-headings text-4xl font-bold">The Revolt Solution</h2>
			<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				We don't just teach theory. We deliver a transition architecture designed for developers who
				cannot afford to wait for the grid to "fix itself."
			</p>
			<ul class="space-y-8">
				<li class="flex gap-4">
					<div
						class="flex h-12 w-12 shrink-0 items-center justify-center rounded-sm bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400"
					>
						<Icon name="shield-check" class="h-6 w-6" />
					</div>
					<div>
						<h3 class="mb-1 font-bold">Strategy</h3>
						<p class="text-sm text-neutral-600 dark:text-neutral-400">
							Strong grid access frameworks tailored to asset class.
						</p>
					</div>
				</li>
				<li class="flex gap-4">
					<div
						class="flex h-12 w-12 shrink-0 items-center justify-center rounded-sm bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400"
					>
						<Icon name="user-group" class="h-6 w-6" />
					</div>
					<div>
						<h3 class="mb-1 font-bold">Expertise</h3>
						<p class="text-sm text-neutral-600 dark:text-neutral-400">
							Deep operational insights from former grid engineers.
						</p>
					</div>
				</li>
				<li class="flex gap-4">
					<div
						class="flex h-12 w-12 shrink-0 items-center justify-center rounded-sm bg-primary-100 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400"
					>
						<Icon name="bolt" class="h-6 w-6" />
					</div>
					<div>
						<h3 class="mb-1 font-bold">Execution</h3>
						<p class="text-sm text-neutral-600 dark:text-neutral-400">
							Faster project timelines through process optimization.
						</p>
					</div>
				</li>
			</ul>
		</Col>
		<Col span="6" classes="mt-12 lg:mt-0">
			<div class="relative pb-8">
				<div
					class="relative aspect-video w-full overflow-hidden rounded-tl-lg [-webkit-mask-image:linear-gradient(to_right,black_60%,transparent_100%)] [mask-image:linear-gradient(to_right,black_60%,transparent_100%)]"
				>
					<Image
						src={cubeNetworkImg}
						alt="Digital cube network architecture"
						class="absolute inset-0 h-full w-full object-cover"
					/>
				</div>
				<!-- Support line -->
				<div class="absolute -left-8 bottom-0 h-3 w-[100vw] bg-primary-500 dark:bg-primary-600">
				</div>
			</div>
		</Col>
	</Row>
</Section>
