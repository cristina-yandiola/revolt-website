---
// Solution Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import electricGridImg from '../../../assets/electric-grid.jpg'
---

<Section id="solution" classes="bg-white py-12 lg:py-24 dark:bg-neutral-950">
	<div
		class="absolute -bottom-12 -top-12 left-[calc(50%-50vw)] right-1/2 hidden lg:-bottom-24 lg:-top-24 lg:block"
	>
		<Image
			src={electricGridImg}
			alt="Transmission grid infrastructure"
			class="h-full w-full object-cover grayscale"
		/>
		<div class="absolute inset-0 bg-neutral-950/15 dark:bg-neutral-950/35"></div>
	</div>
	<Row classes="items-stretch gap-y-10">
		<Col span="6" classes="lg:hidden">
			<div class="relative min-h-[360px] overflow-hidden">
				<Image
					src={electricGridImg}
					alt="Transmission grid infrastructure"
					class="absolute inset-0 h-full w-full object-cover grayscale"
				/>
				<div class="absolute inset-0 bg-neutral-950/15 dark:bg-neutral-950/35"></div>
			</div>
		</Col>
		<Col span="6" classes="hidden lg:block" />
		<Col span="6" classes="relative z-10 flex flex-col justify-center lg:pl-12">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">
				Gridscore Platform
			</p>
			<h2
				class="mb-6 max-w-xl font-headings text-3xl font-bold leading-tight text-primary-600 lg:text-4xl"
			>
				Gridscore turns grid constraints into actionable site intelligence
			</h2>
			<p class="mb-10 max-w-xl leading-relaxed text-neutral-600 dark:text-neutral-400">
				Gridscore ranks connection opportunities, capacity signals, and regulatory constraints so
				teams can prioritize viable BESS, renewable, and data centre projects before committing
				capital.
			</p>
			<ul class="space-y-8">
				<li class="flex gap-4">
					<Icon name="shield-check" class="mt-1 h-6 w-6 shrink-0 text-primary-600" />
					<div>
						<h3 class="mb-1 font-bold">Connection Risk Ranking</h3>
						<p class="text-neutral-600 dark:text-neutral-400">
							Compare candidate sites by grid access risk, capacity pressure, and connection
							pathway.
						</p>
					</div>
				</li>
				<li class="flex gap-4">
					<Icon name="user-group" class="mt-1 h-6 w-6 shrink-0 text-primary-600" />
					<div>
						<h3 class="mb-1 font-bold">Shared Pipeline View</h3>
						<p class="text-neutral-600 dark:text-neutral-400">
							Align development, investment, and technical teams around the same grid-score logic.
						</p>
					</div>
				</li>
				<li class="flex gap-4">
					<Icon name="bolt" class="mt-1 h-6 w-6 shrink-0 text-primary-600" />
					<div>
						<h3 class="mb-1 font-bold">Faster Screening</h3>
						<p class="text-neutral-600 dark:text-neutral-400">
							Shorten early-stage qualification by focusing diligence on the strongest grid
							positions.
						</p>
					</div>
				</li>
			</ul>
		</Col>
	</Row>
</Section>
