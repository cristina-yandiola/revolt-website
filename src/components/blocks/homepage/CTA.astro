---
// CTA Section
// ------------
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Button from '../../ui/Button.astro'

interface Props {
	title?: string
	text?: string
	buttonText?: string
	buttonLink?: string
}

const {
	title = 'Ready to find your strongest grid position?',
	text = 'Use Gridscore to compare connection risk, capacity signals, and project viability before capital is committed.',
	buttonText = 'REQUEST A SAMPLE REPORT',
	buttonLink = '/contact'
} = Astro.props
---

<Section id="cta" classes="bg-primary-500 py-16 lg:py-24" mode="dark" padding="none">
	<Row classes="justify-center text-center">
		<Col span="8" classes="lg:col-start-3">
			<h2
				class="mx-auto mb-6 max-w-4xl font-headings text-4xl font-bold leading-tight !text-white lg:text-6xl"
				set:html={title}
			/>
			<p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-primary-50" set:html={text} />
			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<Button
					size="lg"
					style="primary"
					link={buttonLink}
					classes="w-full !border-accent-400 !bg-accent-400 !px-8 !text-neutral-950 hover:!border-accent-300 hover:!bg-accent-300 focus:!border-accent-300 focus:!bg-accent-300 sm:w-auto"
				>
					{buttonText}
				</Button>
			</div>
		</Col>
	</Row>
</Section>
