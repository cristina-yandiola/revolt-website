---
import Col from '../../ui/Col.astro'
import Row from '../../ui/Row.astro'
import Section from '../../ui/Section.astro'
import { Icon } from 'astro-icon/components'

const regulatoryItems = [
	{
    text: 'Grid-access Strategy',
		icon: 'chart-pie',
	},
	{
    text: 'Grid Application Procedures',
		icon: 'file-chart-column-increasing',
	},
	{
    text: 'German Regulatory Landscape',
		icon: 'gauge',
  },
	{
    text: 'Grid Connection Agreements',
		icon: 'bolt',
	}
]
---

<Section id="regulatory" surfaceColor mode="light">
	<Row classes="items-center gap-y-12">
		<Col span="6">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
				Regulatory Navigation
			</p>
			<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
				TSO & DSO Engagement
			</h2>
			<p class="mb-3 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				Germany’s grid-access landscape is evolving rapidly as grid scarcity increases, connection
                processes become more competitive, and regulatory frameworks continue to shift.
			</p>
			<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
            Revolt supports developers and investors with grid application strategy, connection pathway assessment, TSO/DSO engagement advice, and project positioning decisions.
			</p>
		</Col>
		<Col span="5" classes="lg:col-start-8">
			<ul class="space-y-8">
				{
					regulatoryItems.map((point) => (
						<li class="flex items-center gap-3">
							<Icon name={point.icon} class="h-6 w-6 shrink-0 text-primary-700" />
							<div>
								<h3 class="text-lg text-neutral-600">{point.text}</h3>
							</div>
						</li>
					))
				}
			</ul>
		</Col>
	</Row>
</Section>
