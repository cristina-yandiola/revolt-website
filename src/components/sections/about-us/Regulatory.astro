---
import Col from '../../ui/Col.astro'
import Row from '../../ui/Row.astro'
import Section from '../../ui/Section.astro'

const regulatoryItems = [
	{
		text: 'Grid-access Strategy'
	},
	{
		text: 'Grid Application Procedures'
	},
	{
		text: 'German Regulatory Landscape'
  },
	{
		text: 'Grid Connection Agreements'
	}
]
---

<Section id="regulatory" surfaceColor mode="light">
	<Row classes="items-center gap-y-12">
		<Col span="6">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
				Regulatory Navigation
			</p>
			<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
				TSO & DSO Engagement
			</h2>
			<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				Germany’s grid-access landscape is evolving rapidly as grid scarcity increases, connection
				processes become more competitive, and regulatory frameworks continue to shift. Revolt
				supports developers and investors with grid application strategy, connection pathway
				assessment, TSO/DSO engagement advice, and project positioning decisions.
			</p>
			<div class="inline-block bg-accent-500 p-8 text-neutral-900">
				<p class="font-headings text-2xl font-bold leading-tight">Areas of expertise</p>
			</div>
		</Col>
		<Col span="5" classes="lg:col-start-8">
			<div class="space-y-6">
				{
					regulatoryItems.map((item) => (
						<div class="border-l-4 border-primary-500 bg-white p-8 shadow-sm transition-all hover:shadow-md dark:bg-neutral-950">
							<h3 class="mb-2 font-headings text-xl font-bold text-primary-500">{item.text}</h3>
							<!-- <p class="text-neutral-600 dark:text-neutral-400">{item.text}</p> -->
						</div>
					))
				}
			</div>
		</Col>
	</Row>
</Section>
