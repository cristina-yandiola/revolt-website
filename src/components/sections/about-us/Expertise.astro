---
import SectionWithImage from '../../ui/SectionWithImage.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import powerlines from '../../../assets/powerlines-3.jpg'

const stats = [
	{
		value: '12+',
		label: 'Years Experience'
	},
	{
		value: '1GW+',
		label: 'Projects Connected'
	}
]
---

<SectionWithImage id="expertise" image={powerlines} mode="light" surfaceColor>
	<Row classes="items-center">
		<Col classes="relative z-10 lg:pr-16">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
				Grid expertise shaped by execution
			</p>
			<h2 class="mb-6 font-headings text-3xl font-bold leading-tight lg:text-4xl">
				Over a decade of strategic grid expertise
			</h2>
			<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				With over a decade at the forefront of European energy infrastructure, Revolt has witnessed
				the rapid evolution of Germany’s grid landscape and the increasing importance of strategic
				grid positioning for energy infrastructure projects.
			</p>
			<div class="grid grid-cols-2 gap-8">
				{
					stats.map((stat) => (
						<div>
							<div class="mb-1 text-4xl font-black text-primary-500">{stat.value}</div>
							<div class="font-mono text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
								{stat.label}
							</div>
						</div>
					))
				}
			</div>
		</Col>
	</Row>
</SectionWithImage>
