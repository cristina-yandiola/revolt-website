---
import Col from '../../ui/Col.astro'
import Row from '../../ui/Row.astro'
import Section from '../../ui/Section.astro'

const areas = [
	'Grid connection strategy and project positioning',
	'Support navigating TSO/DSO processes and evolving German grid-access frameworks',
	'Site and pipeline prioritisation informed by project-specific grid intelligence',
	'Strategic guidance for BESS and energy infrastructure projects'
]
---

<Section id="strategy-engineering" mode="light">
	<Row classes="mb-16 text-center">
		<Col span="8" classes="lg:col-start-3">
			<h2 class="font-headings text-3xl font-bold leading-tight lg:text-4xl">Areas of support</h2>
		</Col>
	</Row>
	<Row classes="gap-6">
		{
			areas.map((area, i) => (
				<Col span="6">
					<div class="h-full border-2 border-neutral-200 bg-surface-100 p-8">
						<div class="mb-6 flex h-10 w-10 items-center justify-center bg-primary-500 font-mono text-sm font-bold text-white">
							{i + 1}
						</div>
						<h3 class="mb-4 font-headings text-xl font-bold">{area}</h3>
					</div>
				</Col>
			))
		}
	</Row>
</Section>
