---
import Button from '../../../components/ui/Button.astro'
import Col from '../../../components/ui/Col.astro'
import Row from '../../../components/ui/Row.astro'
import Section from '../../../components/ui/Section.astro'
---

<Section id="strategy-hero" mode="light" surfaceColor>
	<Row classes="items-center">
		<Col span="7" classes="relative z-10">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
				STRATEGIC GRID ADVISORY
			</p>
			<h1 class="mb-6 font-headings text-3xl font-bold leading-tight lg:text-4xl">Grid Strategy</h1>
			<p class="mb-10 max-w-xl text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
				Project-specific grid intelligence and strategic advisory for developers and investors
				navigating Germany’s evolving grid landscape.
			</p>
			<div class="flex flex-wrap gap-4">
				<Button size="lg" style="accent-light" link="/contact">Book a Call</Button>
				<Button size="lg" style="neutral" variation="outline" link="/gridscore"
					>View GridScore</Button
				>
			</div>
		</Col>
	</Row>
</Section>
