---
import SectionWithImage from '../../../components/ui/SectionWithImage.astro'
import electricGridImg from '../../../assets/powerlines-2-upscaled.png'
import Col from '../../../components/ui/Col.astro'
import Row from '../../../components/ui/Row.astro'
import { Icon } from 'astro-icon/components'

const capabilities = [
	{
		text: 'Project-specific assessment of grid connection risk, network constraints, and regional capacity dynamics for energy infrastructure projects.',
		icon: 'shield-check'
	},
	{
		text: 'Strategic guidance on grid applications, connection pathways, and evolving TSO/DSO and BNetzA frameworks.',
		icon: 'scale'
	},
	{
		text: 'Support prioritizing sites, evaluating development risk, and improving grid-related project positioning and performance.',
		icon: 'arrow-trending-up'
	}
]
---

<SectionWithImage id="strategy-scope" mode="light" padding="none" image={electricGridImg} reverse>
	<Row>
		<Col span="12" classes="relative z-10 flex flex-col justify-center lg:pl-12 py-16 lg:py-28">
			<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
				Capabilities
			</p>
			<h2 class="mb-6 max-w-xl font-headings text-3xl font-bold leading-tight lg:text-4xl">
				Scope
			</h2>
			<ul class="space-y-8">
				{
					capabilities.map((point) => (
						<li class="flex items-center gap-3">
							<Icon name={point.icon} class="h-8 w-8 shrink-0 text-primary-700" />
							<div>
								<h3 class="text-base text-neutral-600">{point.text}</h3>
							</div>
						</li>
					))
				}
			</ul>
		</Col>
	</Row>
</SectionWithImage>
