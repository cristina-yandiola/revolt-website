---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Button from '../components/ui/Button.astro'
import Col from '../components/ui/Col.astro'
import Row from '../components/ui/Row.astro'
import Section from '../components/ui/Section.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import CTA from '../components/blocks/homepage/CTA.astro'

// Assets
import cubeGridImg from '../assets/cube-grid-electric.webp'
import electricGridImg from '../assets/electric-grid.jpg'
import networkImg from '../assets/futuristic-digital-cube-network-with-glowing-neon-blue-lights-and-data-points-distribution-photo.jpg'

const SEO = {
	title: 'GridScore | Revolt Grid Access Intelligence',
	description:
		'GridScore ranks points of connection, capacity signals, and grid access risk before development capital is committed.'
}

const frameworkItems = [
	{
		icon: 'document-chart-bar',
		text: 'Automated technical assessment of substation capacity and network constraints across priority markets.'
	},
	{
		icon: 'shield-check',
		text: 'Connection success modelling based on approval patterns, historical queues, and regional load profiles.'
	},
	{
		icon: 'bolt',
		text: 'Real-time risk scoring for curtailment exposure, congestion pressure, and deployment timing.'
	}
]

const stats = [
	{
		value: '400+',
		label: 'Grid scenarios mapped',
		classes: 'bg-neutral-100 dark:bg-neutral-900',
		text: 'text-primary-500'
	},
	{
		value: '280+',
		label: 'Substations tracked',
		classes: 'bg-accent-400 text-neutral-950',
		text: 'text-neutral-950'
	},
	{
		value: '12GW+',
		label: 'Projects analyzed',
		classes: 'bg-neutral-200 dark:bg-neutral-800',
		text: 'text-primary-500'
	},
	{
		value: 'Tier 1',
		label: 'Bankable data',
		classes: 'border border-neutral-900 dark:border-neutral-100',
		text: 'text-primary-500'
	}
]

const steps = [
	{
		number: '1',
		title: 'Location Intake',
		text: 'Provide GPS coordinates, substation IDs, or a proposed development pipeline for analysis.'
	},
	{
		number: '2',
		title: 'Analytical Pass',
		text: 'GridScore cross-references connection constraints, network capacity signals, and historical queue data.'
	},
	{
		number: '3',
		title: 'Risk Dossier',
		text: 'Receive a concise technical report and ranked view of which grid positions deserve diligence.'
	}
]

const supportItems = [
	{
		title: 'Interconnection Filing Support',
		text: 'Expert guidance on DNO, TSO, and utility application optimization.'
	},
	{
		title: 'Curtailment Analysis',
		text: 'Downside-risk protection through constraint, congestion, and nodal-signal review.'
	}
]
---

<Layout title={SEO.title} description={SEO.description}>
	<Section
		id="gridscore-hero"
		classes="bg-neutral-50 py-20 lg:py-28 dark:bg-neutral-950 overflow-hidden"
	>
		<div
			class="absolute -bottom-20 -top-20 left-1/2 right-[calc(50%-50vw)] hidden lg:-bottom-28 lg:-top-28 lg:block"
		>
			<Image
				src={networkImg}
				alt="Technical grid visualization"
				class="h-full w-full object-cover"
				loading="eager"
			/>
			<div
				class="absolute inset-0 z-10 h-full w-full bg-gradient-to-r from-neutral-50/75 from-[100%] to-transparent backdrop-blur-md md:from-neutral-50 md:from-[60%] md:backdrop-blur-none lg:from-[0%] dark:from-neutral-950/75 md:dark:from-neutral-950"
			>
			</div>
			<div class="absolute inset-0 z-20 bg-primary-500/10 dark:bg-primary-400/5"></div>
		</div>
		<Row classes="items-center gap-y-12">
			<Col span="5" classes="relative z-10">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					The Technical Edge
				</p>
				<h1 class="mb-6 font-headings text-5xl font-bold leading-tight lg:text-4xl">GridScore</h1>
				<p class="mb-10 max-w-xl text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					Rank points of connection and assess grid risk before committing development capital.
				</p>
				<Button
					size="lg"
					link="/contact"
					classes="!bg-accent-400 !text-neutral-950 hover:!bg-accent-300 focus:!bg-accent-300"
				>
					REQUEST SAMPLE REPORT
				</Button>
			</Col>
			<Col span="6" classes="hidden lg:block lg:col-start-7" />
		</Row>
	</Section>

	<Section id="gridscore-framework" classes="bg-white py-16 lg:py-28 dark:bg-neutral-950">
		<Row classes="items-center gap-y-12">
			<Col span="5">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Analysis Framework
				</p>
				<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					What GridScore does
				</h2>
				<ul class="space-y-6">
					{
						frameworkItems.map((item) => (
							<li class="flex gap-4">
								<Icon name={item.icon} class="mt-1 h-5 w-5 shrink-0 text-primary-500" />
								<p class="leading-relaxed text-neutral-600 dark:text-neutral-400">{item.text}</p>
							</li>
						))
					}
				</ul>
			</Col>
			<Col span="5" classes="lg:col-start-8">
				<div class="grid gap-4 sm:grid-cols-2">
					{
						stats.map((stat) => (
							<div class:list={['flex min-h-44 flex-col justify-end p-8', stat.classes]}>
								<p class:list={['mb-1 font-headings text-4xl font-bold tracking-tight', stat.text]}>
									{stat.value}
								</p>
								<p
									class:list={[
										'font-mono text-xs font-bold uppercase tracking-[0.18em]',
										stat.text
									]}
								>
									{stat.label}
								</p>
							</div>
						))
					}
				</div>
			</Col>
		</Row>
	</Section>

	<Section id="gridscore-context" classes="bg-neutral-100 py-16 lg:py-28 dark:bg-neutral-900">
		<div
			class="absolute -bottom-16 -top-16 left-[calc(50%-50vw)] right-1/2 hidden lg:-bottom-28 lg:-top-28 lg:block"
		>
			<Image
				src={electricGridImg}
				alt="Energy grid infrastructure"
				class="h-full w-full object-cover"
			/>
			<div class="absolute inset-0 bg-neutral-950/10 dark:bg-neutral-950/30"></div>
		</div>
		<Row classes="items-center gap-y-10">
			<Col span="6" classes="lg:hidden">
				<div class="relative min-h-[340px] overflow-hidden">
					<Image
						src={electricGridImg}
						alt="Energy grid infrastructure"
						class="absolute inset-0 h-full w-full object-cover"
					/>
				</div>
			</Col>
			<Col span="6" classes="hidden lg:block" />
			<Col span="6" classes="relative z-10 lg:pl-12">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Strategic Context
				</p>
				<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					Why grid data matters now
				</h2>
				<p class="mb-6 leading-relaxed text-neutral-600 dark:text-neutral-400">
					As the energy transition accelerates, the grid has become the ultimate bottleneck. Project
					failure rates rise when interconnection risk is discovered after land, capital, and
					engineering work are already committed.
				</p>
				<p class="mb-8 leading-relaxed text-neutral-600 dark:text-neutral-400">
					Securing development capital requires empirical proof of connection feasibility. GridScore
					provides the technical validation needed by developers, lenders, and investment
					committees.
				</p>
				<ul class="space-y-4">
					<li class="flex items-center gap-3 font-semibold text-neutral-700 dark:text-neutral-200">
						<Icon name="check-circle" class="h-5 w-5 text-primary-500" />
						Mitigate interconnection risk
					</li>
					<li class="flex items-center gap-3 font-semibold text-neutral-700 dark:text-neutral-200">
						<Icon name="check-circle" class="h-5 w-5 text-primary-500" />
						Optimize asset deployment
					</li>
				</ul>
			</Col>
		</Row>
	</Section>

	<Section id="gridscore-flow" classes="bg-white py-16 lg:py-28 dark:bg-neutral-950">
		<Row classes="mb-12 text-center">
			<Col span="8" classes="lg:col-start-3">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Operational Flow
				</p>
				<h2 class="font-headings text-3xl font-bold leading-tight lg:text-4xl">
					How GridScore is delivered
				</h2>
			</Col>
		</Row>
		<Row classes="gap-y-6">
			{
				steps.map((step) => (
					<Col span="4">
						<div class="h-full border border-neutral-200 bg-neutral-50 p-8 dark:border-neutral-800 dark:bg-neutral-900">
							<div class="mb-6 flex h-10 w-10 items-center justify-center bg-primary-500 font-mono text-sm font-bold text-white">
								{step.number}
							</div>
							<h3 class="mb-4 font-headings text-xl font-bold">{step.title}</h3>
							<p class="leading-relaxed text-neutral-600 dark:text-neutral-400">{step.text}</p>
						</div>
					</Col>
				))
			}
		</Row>
	</Section>

	<Section id="gridscore-support" classes="bg-white py-16 lg:py-28 dark:bg-neutral-950">
		<div
			class="absolute -bottom-16 -top-16 left-1/2 right-[calc(50%-50vw)] hidden bg-neutral-950 lg:-bottom-28 lg:-top-28 lg:block"
		>
			<Image
				src={cubeGridImg}
				alt="Energy technology signal map"
				class="h-full w-full object-cover"
			/>
			<div class="absolute inset-0 bg-neutral-950/35"></div>
		</div>
		<Row classes="items-center gap-y-10">
			<Col span="5" classes="relative z-10">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Beyond the Score
				</p>
				<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					Grid Strategy Support
				</h2>
				<p class="mb-8 leading-relaxed text-neutral-600 dark:text-neutral-400">
					Data is only as valuable as the decisions it informs. Revolt pairs GridScore with
					technical advisory support to help developers navigate filings, capacity constraints, and
					BESS sizing decisions.
				</p>
				<div class="space-y-4">
					{
						supportItems.map((item) => (
							<div class="border-l-4 border-primary-500 bg-neutral-50 p-6 dark:bg-neutral-900">
								<h3 class="mb-2 font-bold">{item.title}</h3>
								<p class="text-neutral-600 dark:text-neutral-400">{item.text}</p>
							</div>
						))
					}
				</div>
			</Col>
			<Col span="6" classes="lg:col-start-7 lg:hidden">
				<div class="relative min-h-[360px] overflow-hidden bg-neutral-950">
					<Image
						src={cubeGridImg}
						alt="Energy technology signal map"
						class="absolute inset-0 h-full w-full object-cover"
					/>
				</div>
			</Col>
			<Col span="6" classes="hidden lg:block" />
		</Row>
	</Section>

	<CTA />
</Layout>
