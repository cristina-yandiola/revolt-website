---
// Components
import Layout from '../layouts/Layout.astro'
import Section from '../components/ui/Section.astro'
import Row from '../components/ui/Row.astro'
import Col from '../components/ui/Col.astro'
import CTA from '../components/blocks/homepage/CTA.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

// Assets
import electricGridImg from '../assets/electric-grid.jpg'
import cubeGridImg from '../assets/cube-grid-electric.webp'

// Content
// - SEO
const SEO = {
	title: 'About Revolt | Technical Grid Strategy Experts',
	description:
		'Revolt is the technical anchor for energy investors, providing the data and strategic engagement necessary for successful grid connection in Germany’s evolving landscape.'
}

const stats = [
	{
		value: '12+',
		label: 'Years Experience'
	},
	{
		value: '1GW+',
		label: 'Projects Connected'
	}
]

const bessFeatures = [
	'Technical Feasibility Assessments',
	'BNetzA Regulatory Alignment',
	'System Integration Strategies'
]

const regulatoryItems = [
	{
		title: 'BNetzA Compliance',
		text: 'Direct alignment with the Federal Network Agency for seamless project approval.'
	},
	{
		title: 'TSO Engagement',
		text: 'High-level negotiation and technical integration with TenneT, 50Hertz, Amprion, and TransnetBW.'
	},
	{
		title: 'Infrastructure Audit',
		text: 'Deep-dive technical due diligence for existing and planned grid assets.'
	}
]
---

<Layout title={SEO.title} description={SEO.description}>
	<!-- 1. Hero Section -->
	<Section
		id="about-hero"
		classes="pt-24 pb-12 lg:pt-32 lg:pb-32 bg-white dark:bg-neutral-950 overflow-hidden relative"
	>
		<Row>
			<Col span="8" classes="flex flex-col justify-center z-10 relative">
				<p class="mb-6 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					The Future of Infrastructure
				</p>
				<h1 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					Navigating the complexities of Germany's power grid.
				</h1>
				<p class="max-w-xl text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					Revolt is the technical anchor for energy investors, providing the data and strategic
					engagement necessary for successful grid connection in Germany’s evolving regulatory
					landscape.
				</p>
			</Col>
		</Row>
	</Section>

	<!-- 2. Expertise Section: Bleed Image Right -->
	<Section
		id="expertise"
		classes="bg-neutral-50 dark:bg-neutral-900 overflow-hidden"
		padding="none"
	>
		<div class="absolute -bottom-0 -top-0 left-1/2 right-[calc(50%-50vw)] hidden lg:block">
			<Image src={electricGridImg} alt="Technical power lines" class="h-full w-full object-cover" />
		</div>
		<Row classes="items-center py-16 lg:py-32">
			<Col span="6" classes="relative z-10 lg:pr-16">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Our Legacy
				</p>
				<h2 class="mb-6 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					Over a decade of strategic grid expertise
				</h2>
				<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					With over ten years on the front lines of European energy infrastructure, Revolt has
					witnessed every major shift in the German energy transition. We don't just observe the
					market; we actively shape the technical frameworks that define it.
				</p>
				<div class="grid grid-cols-2 gap-8">
					{
						stats.map((stat) => (
							<div>
								<div class="mb-1 text-4xl font-black text-primary-500">{stat.value}</div>
								<div class="font-mono text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
									{stat.label}
								</div>
							</div>
						))
					}
				</div>
			</Col>
			<Col span="6" classes="lg:hidden mt-12">
				<div class="relative min-h-[400px]">
					<Image
						src={electricGridImg}
						alt="Technical power lines"
						class="absolute inset-0 h-full w-full object-cover"
					/>
				</div>
			</Col>
		</Row>
	</Section>

	<!-- 3. BESS Section: Bleed Image Left -->
	<Section id="bess" classes="bg-white dark:bg-neutral-950 overflow-hidden" padding="none">
		<div class="absolute -bottom-0 -top-0 left-[calc(50%-50vw)] right-1/2 hidden lg:block">
			<Image
				src={cubeGridImg}
				alt="BESS facility visualization"
				class="h-full w-full object-cover"
			/>
		</div>
		<Row classes="items-center py-16 lg:py-32">
			<Col span="6" classes="lg:hidden mb-12">
				<div class="relative min-h-[400px]">
					<Image
						src={cubeGridImg}
						alt="BESS facility visualization"
						class="absolute inset-0 h-full w-full object-cover"
					/>
				</div>
			</Col>
			<Col span="6" classes="hidden lg:block" />
			<Col span="6" classes="relative z-10 lg:pl-16">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Core Competency
				</p>
				<h2 class="mb-6 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					Leading the BESS Revolution
				</h2>
				<p class="mb-8 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					Battery Energy Storage Systems (BESS) are the backbone of grid stability. Revolt
					specializes in the high-stakes engineering and negotiation required to bring large-scale
					infrastructure projects from planning to activation.
				</p>
				<ul class="space-y-4">
					{
						bessFeatures.map((feature) => (
							<li class="flex items-start gap-3">
								<Icon name="check-circle" class="h-6 w-6 shrink-0 text-primary-500" />
								<span class="text-neutral-700 dark:text-neutral-200">{feature}</span>
							</li>
						))
					}
				</ul>
			</Col>
		</Row>
	</Section>

	<!-- 4. Regulation / TSO Section -->
	<Section id="regulatory" classes="py-16 lg:py-32 bg-neutral-50 dark:bg-neutral-900">
		<Row classes="items-center gap-y-12">
			<Col span="6">
				<p class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.2em] text-primary-500">
					Regulatory Navigation
				</p>
				<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					TSO & DSO Engagement
				</h2>
				<p class="mb-10 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					The German grid is a complex web of Transmission and Distribution System Operators. Revolt
					acts as your primary liaison, ensuring technical compliance with BNetzA standards while
					accelerating the connection timeline through established relationships.
				</p>
				<div class="inline-block bg-primary-500 p-8 text-white">
					<p class="font-headings text-2xl font-bold leading-tight">
						Precision-engineered grid strategies for the modern age.
					</p>
				</div>
			</Col>
			<Col span="5" classes="lg:col-start-8">
				<div class="space-y-6">
					{
						regulatoryItems.map((item) => (
							<div class="border-l-4 border-primary-500 bg-white p-8 shadow-sm transition-all hover:shadow-md dark:bg-neutral-950">
								<h3 class="mb-2 font-headings text-xl font-bold text-primary-500">{item.title}</h3>
								<p class="text-neutral-600 dark:text-neutral-400">{item.text}</p>
							</div>
						))
					}
				</div>
			</Col>
		</Row>
	</Section>

	<!-- 5. Call to Action -->
	<CTA
		title="Ready to secure your grid connection?"
		text="Discuss your project with our engineering team to secure your position in the German energy transition."
		buttonText="SCHEDULE TECHNICAL REVIEW"
		buttonLink="/contact"
	/>
</Layout>
