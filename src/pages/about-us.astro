---
import Layout from '../layouts/Layout.astro'
import CTA from '../components/blocks/homepage/CTA.astro'
import Hero from '../components/sections/about-us/Hero.astro'
import Expertise from '../components/sections/about-us/Expertise.astro'
import Bess from '../components/sections/about-us/Bess.astro'
import Regulatory from '../components/sections/about-us/Regulatory.astro'

const SEO = {
	title: 'About Revolt | Technical Grid Strategy Experts',
	description:
		'Revolt is the technical anchor for energy investors, providing the data and strategic engagement necessary for successful grid connection in Germany’s evolving landscape.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero />
	<Expertise />
	<Bess />
	<Regulatory />
	<CTA
		title="Understand the grid dynamics shaping your project."
		text="Discuss your project, pipeline, or grid-access strategy with Revolt."
		buttonText="BOOK A CALL"
		buttonLink="mailto:info@revoltgrid.de?subject=GridScore%20Sample%20Report%20Request&body=Hi%2C%20I%20would%20like%20to%20request%20a%20sample%20GridScore%20report%20and%20learn%20more%20about%20the%20product."
		classes="!bg-surface-100"
	/>
</Layout>
