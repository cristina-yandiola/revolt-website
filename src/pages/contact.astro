---
// Components
import Layout from '../layouts/Layout.astro'
import Section from '../components/ui/Section.astro'
import Row from '../components/ui/Row.astro'
import Col from '../components/ui/Col.astro'
import { Icon } from 'astro-icon/components'
import Button from '../components/ui/Button.astro'
import InputField from '../components/ui/forms/form-elements/InputField.astro'
import DropdownField from '../components/ui/forms/form-elements/DropdownField.astro'
import CheckboxField from '../components/ui/forms/form-elements/CheckboxField.astro'
import TextArea from '../components/ui/forms/form-elements/TextArea.astro'

const SEO = {
	title: 'Contact Revolt | Strategic Grid Engagement',
	description:
		'Connect with the Revolt technical team for GridScore™ analytics or strategic advisory for BESS deployment.'
}

const dropdownOptions = [
	{ value: 'GridScore Ranking', label: 'GridScore Ranking' },
	{ value: 'Tailored Assessment', label: 'Tailored Assessment' },
	{ value: 'Strategic Grid Advisory', label: 'Strategic Grid Advisory' },
	{ value: 'Other', label: 'Other' }
]
---

<Layout title={SEO.title} description={SEO.description}>
	<Section id="contact-form" mode="light" surfaceColor>
		<Row classes="gap-y-16">
			<Col span="5">
				<h2 class="mb-8 font-headings text-3xl font-bold leading-tight lg:text-4xl">
					GET IN TOUCH
				</h2>
				<p class="mb-12 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
					Get in touch to discuss GridScore, project-specific assessments, or strategic grid
					advisory.
				</p>
				<div class="space-y-8">
					<div class="group flex items-start gap-4">
						<div
							class="flex h-12 w-12 shrink-0 items-center justify-center bg-primary-500/10 text-primary-500 transition-transform group-hover:scale-110 dark:bg-primary-400/10"
						>
							<Icon name="circle-stack" class="h-6 w-6" />
						</div>
						<div>
							<h3 class="font-headings text-lg font-bold">Request GridScore Demo</h3>
							<p class="font-mono text-sm font-semibold text-primary-500">info@revoltgrid.de</p>
						</div>
					</div>
					<div class="group flex items-start gap-4">
						<div
							class="flex h-12 w-12 shrink-0 items-center justify-center bg-primary-500/10 text-primary-500 transition-transform group-hover:scale-110 dark:bg-primary-400/10"
						>
							<Icon name="user-group" class="h-6 w-6" />
						</div>
						<div>
							<h3 class="font-headings text-lg font-bold">Strategic inquiries</h3>
							<p class="font-mono text-sm font-semibold text-primary-500">contact@revoltgrid.de</p>
						</div>
					</div>
				</div>
			</Col>
			<Col span="6" classes="lg:col-start-7">
				<div
					class="border border-neutral-200 bg-white p-8 shadow-sm lg:p-12 dark:border-neutral-800 dark:bg-neutral-950"
				>
					<div data-fs-success class="mb-6 font-headings text-lg font-bold text-primary-500"></div>
					<div data-fs-error class="mb-6 text-red-500"></div>

					<form id="fs-contact-form" class="space-y-6">
						<InputField id="name" label="Full Name" type="text" data-fs-field required />
						<InputField id="email" label="Work Email" type="email" data-fs-field required />
						<InputField
							id="company"
							label="Company / Organization"
							type="text"
							data-fs-field
							required
						/>
						<DropdownField
							id="interested"
							label="What are you interested in?"
							options={dropdownOptions}
							data-fs-field
						/>
						<TextArea id="message" label="Message" data-fs-field required />
						<CheckboxField
							id="consent"
							label="I agree to the privacy policy."
							data-fs-field
							required
						/>
						<input
							type="hidden"
							name="g-recaptcha-response"
							id="g-recaptcha-response"
							data-fs-field
						/>
						<Button
							style="accent-light"
							size="lg"
							type="submit"
							classes="w-full"
							data-fs-submit-btn
						>
							SEND INQUIRY
							<Icon name="arrow-right" class="ml-2 h-4 w-4" />
						</Button>
					</form>
				</div>
			</Col>
		</Row>
	</Section>
	<script is:inline>
		// This runs on the initial load AND every time you switch pages asynchronously
		document.addEventListener('astro:page-load', () => {
			const form = document.getElementById('fs-contact-form')

			// Exit immediately if the user navigated to a page without the form
			if (!form) return

			// A. Restore the Google reCAPTCHA Badge cleanly
			// If the badge got wiped by the page transition, re-inject the script
			if (!document.querySelector('.grecaptcha-badge')) {
				const script = document.createElement('script')
				script.src =
					'https://www.google.com/recaptcha/api.js?render=6LfeH_EsAAAAAN97gCRIAq_znfgU_z8VFhAzdFNO'
				document.body.appendChild(script)
			}

			// B. Re-attach the Form Interceptor to the new DOM element
			form.addEventListener('submit', function (e) {
				const recaptchaInput = document.getElementById('g-recaptcha-response')
				const submitBtn = form.querySelector('[data-fs-submit-btn]')

				if (!recaptchaInput.value) {
					e.preventDefault()
					e.stopImmediatePropagation()

					if (submitBtn) submitBtn.disabled = true

					grecaptcha.ready(function () {
						grecaptcha
							.execute('6LfeH_EsAAAAAN97gCRIAq_znfgU_z8VFhAzdFNO', { action: 'submit' })
							.then(function (token) {
								recaptchaInput.value = token
								if (submitBtn) submitBtn.disabled = false
								form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }))
							})
					})
				}
			})

			// C. Re-initialize Formspree on the new form element
			window.formspree =
				window.formspree ||
				function () {
					;(formspree.q = formspree.q || []).push(arguments)
				}
			formspree('initForm', { formElement: '#fs-contact-form', formId: 'mbdbjepv' })
		})
	</script>
	<script is:inline src="https://unpkg.com/@formspree/ajax@1" defer></script>
</Layout>
