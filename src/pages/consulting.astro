---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Feature from '../components/blocks/features/FeatureSticky.astro'
import Hero from '../components/blocks/hero/ConsultingHero.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'

// Data
import consultingData from '../data/json-files/consultingData.json'
// - Consulting Categories
const strategyPlanning = consultingData.filter((service) => service.category === 'Strategy & Planning')
const executionSupport = consultingData.filter((service) => service.category === 'Execution & Support')
const techAutomation = consultingData.filter((service) => service.category === 'Technology & Automation')
const trainingEnablement = consultingData.filter((service) => service.category === 'Training & Enablement')

// Assets
import heroImage from '../assets/hero-01.png'

// Content
// - SEO
const SEO = {
	title: 'Revolt | Grid Access Consulting',
	description:
		"Discover Revolt's comprehensive grid access consulting. We offer strategy, execution, automation, and training to accelerate your interconnection timeline."
}
// - Page Header
const header = {
	title: 'Our <strong>Consulting</strong>',
	text: 'Comprehensive consulting solutions to accelerate your grid connection and eliminate bottlenecks. We help developers, operators, and funds mitigate risks and streamline processes from initial site screening through to successful grid connection.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} image={heroImage} />
	
	<Feature
		title="Strategy & Planning"
		text="Build a strong foundation with data-driven insights and strategic structuring to maximize your connection success rates."
		data={strategyPlanning}
	/>
	
	<Feature
		title="Execution & Support"
		text="Leverage our deep operational expertise to navigate complex grid operator interfaces and secure your approvals faster."
		data={executionSupport}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	
	<Feature
		title="Technology & Automation"
		text="Cut manual workload and accelerate processes using our proprietary automation tools and streamlined workflows."
		data={techAutomation}
	/>
	
	<Feature
		title="Training & Enablement"
		text="Equip your team with the knowledge and operational competence needed to execute faster from day one."
		data={trainingEnablement}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	
	<CTA 
		title="Ready to accelerate your grid access?" 
		text="Get expert consulting guidance on navigating complex interconnection processes for your project."
	/>
</Layout>
