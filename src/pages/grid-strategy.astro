---
import Layout from '../layouts/Layout.astro'
import CTA from '../components/blocks/homepage/CTA.astro'

import Hero from '../components/sections/grid-strategy/Hero.astro'
import Capabilities from '../components/sections/grid-strategy/Capabilities.astro'
import Methodology from '../components/sections/grid-strategy/Methodology.astro'
import Engineering from '../components/sections/grid-strategy/Engineering.astro'

const SEO = {
	title: 'Grid Strategy | Revolt Grid Access Consulting',
	description:
		'Supporting investors and developers with high-fidelity grid connection decisions. Navigate complexity with Revolt’s proprietary analytics engine.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero />
	<Capabilities />
	<Methodology />
	<Engineering />
	<CTA
		title="Ready to find your strongest grid position?"
		text="Discuss your project, development pipeline, or grid-access strategy with Revolt."
		buttonText="BOOK A CALL"
		secondaryButtonText="View GridScore"
		secondaryButtonLink="/gridscore"
	/>
</Layout>
