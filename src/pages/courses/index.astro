---
// Courses Index Page
// ------------
// Description: The courses index page.

// Components
// - Layout
import Layout from '../../layouts/Layout.astro'
// - UI
import Hero from '../../components/blocks/hero/PageHeader.astro'
import CoursesPosts from '../../components/blocks/courses/CoursesPosts.astro'

// Data
import { getCollection } from 'astro:content'

// Content
// - SEO
const SEO = {
	title: 'Revolt | Latest Revolt Courses',
	description:
		"Explore Revolt's latest courses designed to enhance productivity, ensure top-notch security, and integrate seamlessly with your favorite tools. Join thousands of satisfied users and transform your workflow with Revolt today!"
}
// - Page Header
const header = {
	title: 'The <strong>Revolt</strong> Courses',
	text: 'Stay informed, stay productive. All the latest from the world of Revolt.'
}

const allCourses = await getCollection('courses')
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<CoursesPosts data={allCourses} />
</Layout>
