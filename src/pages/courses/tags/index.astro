---
const isHidden = true

if (isHidden) {
	return new Response(null, {
		status: 404,
		statusText: 'Not found'
	})
}
// Blog Tags Page
// ------------
// Description: The blog tags page.

// Components
// - Layout
import Layout from '../../../layouts/Layout.astro'
// - UI
import Hero from '../../../components/blocks/hero/PageHeader.astro'
import CoursesPosts from '../../../components/blocks/courses/CoursesPosts.astro'

// Data
import { getCollection } from 'astro:content'
const allPosts = await getCollection('courses')
---

<Layout>
	<Hero title="Tags" />
	<CoursesPosts data={allPosts} />
</Layout>
